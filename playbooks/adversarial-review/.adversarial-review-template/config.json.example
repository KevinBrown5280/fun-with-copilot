{
  "primary_language": "csharp",
  "framework": "aspnet-core",
  "exclude_patterns": [
    "*.env",
    "*.pfx",
    "*.key",
    "*.pem",
    "migrations/",
    "wwwroot/lib/",
    "node_modules/",
    "*.min.js",
    "publish/",
    "dist/"
  ],
  "min_severity": "low",
  "default_mode": "review-only",
  "known_safe": [
    "Example: Intentional use of dynamic SQL in stored procedure generator — reviewed 2025-01-15"
  ]
}
